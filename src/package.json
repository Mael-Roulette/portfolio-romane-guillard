{
  "name": "base",
  "version": "1.0.0",
  "main": "app.js",
  "scripts": {
    "watch": "concurrently \"npm run watch:css\" \"npm run watch:js\"",
    "build": "npm run build:css && npm run build:js",
    "watch:css": "sass --watch --style=compressed ./scss/main.scss ../dist/styles.css",
    "watch:js": "node scripts/build.js --watch",
    "build:css": "sass --style=compressed ./scss/main.scss ../dist/styles.css",
    "build:js": "node scripts/build.js"
  },
  "author": "Maël Roulette",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "concurrently": "^8.2.2",
    "esbuild": "^0.21.5",
    "swiper": "^12.1.2"
  }
}
